# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API Configuration (required - point to your deployed API)
VITE_API_URL=https://your-api.vercel.app

# Error Tracking (optional — no-op without DSN)
# VITE_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456

# Sentry Source Maps (optional — only needed in CI/CD for source map uploads)
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=antechamber-console
# SENTRY_AUTH_TOKEN=sntrys_...
